# ===================== 微信支付 v3 配置 =====================
# 复制本文件为 .env 并填入真实值。敏感信息（私钥/密钥）务必放在环境变量，
# 切勿写入 data/system_setting.json 或提交到代码仓库。

# 小程序 AppID（也可在后台「系统设置」中配置 wx_appid）
WX_APPID=

# 微信支付商户号
WX_MCH_ID=

# APIv3 密钥（32 字节，商户平台 -> APIv3 密钥处设置）
WX_API_KEY_V3=

# 商户 API 证书序列号（apiclient_cert.pem 中的序列号）
WX_MCH_SERIAL_NO=

# 商户 API 私钥（apiclient_key.pem 全文，注意保留换行）
# 推荐从文件读取，例如把私钥存为 deploy/wx_private_key.pem 后：
#   WX_MCH_PRIVATE_KEY=$(cat deploy/wx_private_key.pem)
WX_MCH_PRIVATE_KEY=

# 支付结果异步通知地址（必须是公网可访问的 HTTPS 地址）
WX_PAY_NOTIFY_URL=https://your-domain.com/api/payment/notify

# 退款结果异步通知地址（默认与支付通知相同）
WX_REFUND_NOTIFY_URL=https://your-domain.com/api/payment/refund/notify

# 订单支付超时时间（秒，默认 1800 = 30 分钟）
WX_ORDER_TIMEOUT=1800

# 微信支付 API 基础地址（一般无需修改）
WX_PAY_BASE_URL=https://api.mch.weixin.qq.com

# ===================== 小程序登录 / 订阅消息 =====================
# 小程序 AppSecret（用于 code 换 openid 的 jscode2session，及获取 access_token 下发订阅消息）
# 未配置时登录与订阅消息走 mock，不影响本地联调
WX_SECRET=

# 订阅消息模板 ID（在「微信公众平台 › 功能 › 订阅消息」申请后填入）
# 前端 miniprogram/utils/config.js 中的 SUBSCRIBE_TMPL 也需填入相同模板 ID
WX_TMPL_ORDER_PAID=       # 支付成功通知
WX_TMPL_ORDER_SHIPPED=    # 发货通知

# 订阅消息跳转小程序版本：developer(开发版) / trial(体验版) / formal(正式版)
WX_MP_STATE=formal

# ===================== 服务配置 =====================
PORT=3001
JWT_SECRET=mallstore_dev_secret_2026
NODE_ENV=development
