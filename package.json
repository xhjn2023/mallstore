{
  "name": "mallstore",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "nodemon",
    "start": "tsx server/server.ts",
    "deploy:cloudbase": "tcb cloudrun deploy -e xhjn-d7gfgxcvk06569b48 -s mallstore-api --port 3000 --force",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
