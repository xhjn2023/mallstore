    "dotenv": "^17.2.1",
    "echarts": "^5.5.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-vue-next": "^0.511.0",
    "pg": "^8.22.0",
    "pinia": "^2.2.2",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
