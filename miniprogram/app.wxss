/* app.wxss 全局样式 */
page {
  /* ===== 设计令牌（统一视觉语言，参考主流开源商城 UI 规范） ===== */
  --brand: #ff4444;          /* 主品牌色 */
  --brand-light: #ff6b6b;
  --brand-bg: #fff0f0;        /* 品牌浅色底 */
  --text: #1f1f1f;            /* 主文本 */
  --text-2: #666;             /* 次级文本 */
  --text-3: #999;             /* 辅助文本 */
  --bg: #f5f5f5;              /* 页面背景 */
  --card: #ffffff;            /* 卡片背景 */
  --border: #f0f0f0;          /* 分割线 */
  --radius: 20rpx;            /* 圆角基准 */
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);

  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  -webkit-font-smoothing: antialiased;
}

/* 常用变量 */
.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--card);
  border-radius: var(--radius);
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

/* 区块标题（统一商城各列表页小标题风格） */
.section-card {
  background: var(--card);
  border-radius: var(--radius);
  margin: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}
.section-title::before {
  content: '';
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: var(--brand);
  margin-right: 14rpx;
}
.section-more {
  font-size: 24rpx;
  color: var(--text-3);
}

/* 价格 */
.price {
  color: var(--brand);
  font-weight: 600;
}
.price-symbol {
  font-size: 24rpx;
}
.price-original {
  color: var(--text-3);
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--brand), var(--brand-light));
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  transition: opacity 0.2s;
}
.btn-primary::after {
  border: none;
}
.btn-primary[disabled] {
  opacity: 0.55;
  color: #fff;
}
.btn-outline {
  background: #fff;
  color: var(--brand);
  border: 2rpx solid var(--brand);
  border-radius: 48rpx;
  padding: 18rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  transition: all 0.2s;
}
.btn-outline::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
}
.tag-hot {
  background: var(--brand-bg);
  color: var(--brand);
}
.tag-new {
  background: #e8f5e9;
  color: #4caf50;
}

/* Flex 工具 */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }

/* 文字 */
.text-gray { color: var(--text-3); }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty {
  padding: 120rpx 0;
  text-align: center;
  color: #ccc;
  font-size: 28rpx;
}
.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
}
@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
