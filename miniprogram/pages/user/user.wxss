/* pages/user/user.wxss */
.user-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 用户信息区 */
.profile-section {
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
}

.profile-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.2);
}

.profile-detail {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.profile-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 卡片通用 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 订单快捷入口上移 */
.order-shortcut {
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-more {
  font-size: 24rpx;
  color: #999;
}

.order-icons {
  display: flex;
  justify-content: space-around;
}

.order-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.icon-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.icon-emoji {
  font-size: 48rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #ff4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.icon-text {
  font-size: 24rpx;
  color: #666;
}

/* 菜单列表 */
.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  position: relative;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出登录项（红色，左对齐无箭头） */
.logout-item {
  justify-content: center;
}

.logout-text {
  flex: none;
  margin-left: 20rpx;
  color: #ff4444;
  font-weight: 500;
}

.safe-bottom {
  height: 40rpx;
}
