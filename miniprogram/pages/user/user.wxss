/* pages/user/user.wxss */
.user-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 用户信息区 */
.profile-section {
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  padding: 60rpx 32rpx 80rpx;
  position: relative;
}

.profile-info {
  display: flex;
  align-items: center;
}

/* 编辑资料入口（右上角） */
.edit-entry {
  position: absolute;
  top: 36rpx;
  right: 32rpx;
  z-index: 3;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 28rpx;
}

/* 编辑资料弹层 */
.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1001;
}

.edit-sheet {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 40rpx 36rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.edit-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 36rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.edit-label {
  width: 110rpx;
  font-size: 30rpx;
  color: #333;
  flex: none;
}

/* 头像选择按钮（覆盖原生 button 样式） */
.avatar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: normal;
  box-sizing: border-box;
}
.avatar-btn::after {
  border: none;
}

.edit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f2f2f2;
  border: 2rpx solid #eee;
}

.avatar-tip {
  margin-left: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.edit-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.edit-ph {
  color: #bbb;
}

.edit-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.edit-cancel,
.edit-save {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
.edit-cancel {
  background: #f2f2f2;
  color: #666;
}
.edit-cancel::after,
.edit-save::after {
  border: none;
}
.edit-save {
  background: #ff4444;
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.2);
}

.profile-detail {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.profile-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 卡片通用 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 订单快捷入口上移 */
.order-shortcut {
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.card-more {
  font-size: 24rpx;
  color: #999;
}

.order-icons {
  display: flex;
  justify-content: space-around;
}

.order-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.icon-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.icon-emoji {
  font-size: 48rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #ff4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.icon-text {
  font-size: 24rpx;
  color: #666;
}

/* 菜单列表 */
.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  position: relative;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 退出登录项（红色，左对齐无箭头） */
.logout-item {
  justify-content: center;
}

.logout-text {
  flex: none;
  margin-left: 20rpx;
  color: #ff4444;
  font-weight: 500;
}

.safe-bottom {
  height: 40rpx;
}
