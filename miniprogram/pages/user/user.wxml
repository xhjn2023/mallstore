<!-- pages/user/user.wxml -->
<view class="user-page">
  <!-- 用户信息区 -->
  <view class="profile-section">
    <view class="profile-info" bindtap="onProfileTap">
      <image class="avatar" src="{{userInfo.avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="profile-detail">
        <text class="nickname" wx:if="{{isLogin}}">{{userInfo.nickname || '微信用户'}}</text>
        <text class="nickname" wx:else>点击登录</text>
        <text class="profile-tip" wx:if="{{isLogin && userInfo.phone}}">{{userInfo.phone}}</text>
        <text class="profile-tip" wx:if="{{!isLogin}}">登录后享受更多权益</text>
    </view>
    </view>
  </view>

  <!-- 订单快捷入口 -->
  <view class="order-shortcut card">
    <view class="card-header">
      <text class="card-title">我的订单</text>
      <text class="card-more" bindtap="goOrderList" data-status="-1">全部订单 ></text>
    </view>
    <view class="order-icons">
      <view class="order-icon-item" wx:for="{{orderIcons}}" wx:key="status" bindtap="goOrderList" data-status="{{item.status}}">
        <view class="icon-wrap">
          <text class="icon-emoji">{{item.icon}}</text>
          <text class="badge" wx:if="{{item.count > 0}}">{{item.count}}</text>
        </view>
        <text class="icon-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list card">
    <view class="menu-item" bindtap="goMenu" data-url="/pages/order-list/order-list" data-icon="📋">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goMenu" data-url="/pages/favorite/favorite" data-icon="❤️">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goMenu" data-url="/pages/coupon/coupon" data-icon="🎟️">
      <text class="menu-icon">🎟️</text>
      <text class="menu-text">我的优惠券</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goMenu" data-url="/pages/address/address" data-icon="📍">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="showContact">
      <text class="menu-icon">📞</text>
      <text class="menu-text">客服中心</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goMenu" data-url="/pages/feedback/feedback" data-icon="💬">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="showSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">系统设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
