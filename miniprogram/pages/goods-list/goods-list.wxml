<!-- pages/goods-list/goods-list.wxml -->
<view class="goods-list-page">
  <!-- 排序筛选栏 -->
  <view class="filter-bar">
    <view
      class="filter-item {{sort === item.key ? 'active' : ''}}"
      wx:for="{{sortOptions}}"
      wx:key="key"
      bindtap="onSortTap"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view class="skeleton-wrap" wx:if="{{firstLoading}}">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton skeleton-img"></view>
      <view class="skeleton skeleton-line"></view>
      <view class="skeleton skeleton-line short"></view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-grid" wx:elif="{{productList.length}}">
    <view
      class="product-card"
      wx:for="{{productList}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <image src="{{item.main_image}}" mode="aspectFill" class="product-img" lazy-load />
      <view class="product-info">
        <text class="product-name text-ellipsis-2">{{item.name}}</text>
        <view class="product-bottom">
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{item.priceText}}</text>
          </view>
          <text class="product-sales">已售{{item.salesText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading}}">
    <view class="empty-icon ic ic-box"></view>
    <text class="empty-text">暂无相关商品</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{productList.length && !firstLoading}}">
    <text class="load-text" wx:if="{{loading}}">加载中...</text>
    <text class="load-text" wx:elif="{{noMore}}">— 没有更多了 —</text>
  </view>

  <view class="safe-bottom"></view>
</view>
