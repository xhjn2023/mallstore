/* pages/goods-list/goods-list.wxss */
.goods-list-page {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 20rpx;
}

/* 排序筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  height: 88rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #ededed;
}
.filter-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  height: 88rpx;
  line-height: 88rpx;
  position: relative;
}
.filter-item.active {
  color: #111111;
  font-weight: 600;
}
.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #111111;
  border-radius: 2rpx;
}

/* 骨架屏 */
.skeleton-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx;
}
.skeleton-card {
  width: 348rpx;
}
.skeleton-img {
  width: 100%;
  height: 348rpx;
  border-radius: 16rpx;
}
.skeleton-line {
  width: 100%;
  height: 28rpx;
  margin-top: 16rpx;
  border-radius: 8rpx;
}
.skeleton-line.short {
  width: 60%;
}

/* 商品列表 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx;
}
.product-card {
  width: 348rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #ededed;
}
.product-img {
  width: 100%;
  height: 348rpx;
  background: #fafafa;
}
.product-info {
  padding: 16rpx;
}
.product-name {
  font-size: 26rpx;
  color: #333;
  height: 72rpx;
  line-height: 36rpx;
}
.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
}
.product-price {
  color: #111111;
}
.price-symbol {
  font-size: 22rpx;
}
.price-num {
  font-size: 36rpx;
  font-weight: 600;
}
.product-sales {
  font-size: 20rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  padding: 32rpx 0;
  text-align: center;
}
.load-text {
  font-size: 24rpx;
  color: #999;
}

.safe-bottom {
  height: 40rpx;
}
