<!-- pages/pay-result/pay-result.wxml -->
<view class="pay-result-page">
  <!-- 支付成功 -->
  <view class="result-wrap" wx:if="{{isSuccess}}">
    <view class="result-icon success-icon">
      <text class="icon-mark">✓</text>
    </view>
    <view class="result-title">支付成功</view>
    <view class="result-desc" wx:if="{{orderNo}}">订单号：{{orderNo}}</view>
    <view class="result-tips">感谢您的购买，商家将尽快为您发货</view>

    <view class="btn-group">
      <view class="btn outline" bindtap="goOrderList">查看订单</view>
      <view class="btn primary" bindtap="goShopping">继续购物</view>
    </view>
  </view>

  <!-- 支付失败 -->
  <view class="result-wrap" wx:else>
    <view class="result-icon fail-icon">
      <text class="icon-mark">✕</text>
    </view>
    <view class="result-title">支付失败</view>
    <view class="result-desc" wx:if="{{orderNo}}">订单号：{{orderNo}}</view>
    <view class="result-tips">支付未完成，请稍后重试</view>

    <view class="btn-group">
      <view class="btn outline" bindtap="goOrderList">查看订单</view>
      <view class="btn primary" bindtap="onRetry">重新支付</view>
    </view>
  </view>
</view>
