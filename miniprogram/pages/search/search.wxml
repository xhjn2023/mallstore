<!-- pages/search/search.wxml -->
<view class="search-page">
  <!-- 顶部搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <view class="search-icon ic ic-search"></view>
      <input
        class="search-input"
        type="text"
        placeholder="搜索商品"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onConfirm"
        focus
      />
      <view class="clear-icon ic ic-close" wx:if="{{keyword}}" bindtap="onClearInput"></view>
    </view>
    <text class="search-btn" bindtap="onConfirm">搜索</text>
  </view>

  <!-- 热门搜索 -->
  <view class="section" wx:if="{{hotList.length}}">
    <view class="section-header">
      <view class="title-with-ic"><view class="title-ic ic ic-fire"></view><text class="section-title">热门搜索</text></view>
    </view>
    <view class="hot-list">
      <view
        class="hot-chip"
        wx:for="{{hotList}}"
        wx:key="*this"
        bindtap="onHotTap"
        data-keyword="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="section" wx:if="{{historyList.length}}">
    <view class="section-header">
      <view class="title-with-ic"><view class="title-ic ic ic-clock"></view><text class="section-title">搜索历史</text></view>
      <text class="clear-btn" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{historyList}}"
        wx:key="*this"
        bindtap="onHistoryTap"
        data-keyword="{{item}}"
      >
        <text class="history-text text-ellipsis">{{item}}</text>
        <text class="history-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 空历史提示 -->
  <view class="empty-history" wx:if="{{!hotList.length && !historyList.length}}">
    <view class="empty-icon ic ic-search"></view>
    <text class="empty-text">输入关键词搜索商品</text>
  </view>
</view>
