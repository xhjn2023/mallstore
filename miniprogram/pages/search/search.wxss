/* pages/search/search.wxss */
.search-page {
  min-height: 100vh;
  background: #fafafa;
}

/* 顶部搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  gap: 16rpx;
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #fafafa;
  border-radius: 36rpx;
  padding: 0 24rpx;
  gap: 12rpx;
}
.search-icon {
  font-size: 28rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}
.clear-icon {
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx;
}
.search-btn {
  color: #111111;
  font-size: 30rpx;
  font-weight: 500;
  padding: 0 8rpx;
}

/* 通用 section */
.section {
  margin: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #ededed;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.clear-btn {
  font-size: 24rpx;
  color: #999;
}

/* 热门搜索 */
.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.hot-chip {
  padding: 14rpx 32rpx;
  background: #f5f5f4;
  color: #111111;
  border-radius: 32rpx;
  font-size: 26rpx;
}
.hot-chip:first-child {
  background: #111111;
  color: #fff;
}

/* 搜索历史 */
.history-list {
  display: flex;
  flex-direction: column;
}
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.history-item:last-child {
  border-bottom: none;
}
.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.history-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty-history {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.empty-history .empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}
.empty-history .empty-text {
  font-size: 28rpx;
  color: #999;
}
