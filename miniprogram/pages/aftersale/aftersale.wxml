<!-- pages/aftersale/aftersale.wxml -->
<view class="page">
  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <view class="empty-icon ic ic-tool"></view>
    <text class="empty-text">暂无售后订单</text>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card">
    <view class="card-head">
      <text class="order-no">订单号：{{item.order_no}}</text>
      <text class="status status-{{item.status}}">{{item.status_text}}</text>
    </view>

    <view class="items">
      <view wx:for="{{item.items}}" wx:for-item="g" wx:key="id" class="item">
        <image class="thumb" src="{{g.image}}" mode="aspectFill"></image>
        <view class="info">
          <text class="name">{{g.name}}</text>
          <text class="specs">{{g.specsText}}</text>
          <text class="price">¥{{g.priceText}} ×{{g.quantity}}</text>
        </view>
      </view>
    </view>

    <view class="reason">售后原因：{{item.reasonText}}</view>

    <view class="foot">
      <text class="time">{{item.timeText}}</text>
      <text class="link" bindtap="goOrder" data-id="{{item.order_id}}">查看订单</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
