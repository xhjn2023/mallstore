/* pages/aftersale/aftersale.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f2f2f2;
}
.order-no {
  font-size: 26rpx;
  color: #666;
}
.status {
  font-size: 26rpx;
  font-weight: 600;
}
.status-0 {
  color: #ff9800;
}
.status-1 {
  color: #4caf50;
}
.status-2 {
  color: #f44336;
}

.items {
  padding: 16rpx 0;
}
.item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}
.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f2f2f2;
  flex: none;
}
.info {
  margin-left: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.name {
  font-size: 28rpx;
  color: #333;
}
.specs {
  font-size: 24rpx;
  color: #999;
  margin: 6rpx 0;
}
.price {
  font-size: 26rpx;
  color: #ff4444;
}

.reason {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 0;
  border-top: 1rpx solid #f2f2f2;
}

.foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.time {
  font-size: 24rpx;
  color: #999;
}
.link {
  font-size: 26rpx;
  color: #ff4444;
}

.safe-bottom {
  height: 40rpx;
}
