<!-- pages/order-list/order-list.wxml -->
<view class="order-list-page">
  <!-- 状态标签 -->
  <view class="tabs-bar">
    <view class="tab-item {{activeStatus === t.value ? 'active' : ''}}" wx:for="{{tabs}}" wx:for-item="t" wx:key="value" bindtap="onTabChange" data-value="{{t.value}}">
      <text>{{t.label}}</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{list.length}}">
    <view class="order-card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="order-card-head">
        <text class="order-no">订单号：{{item.order_no}}</text>
        <text class="order-status status-{{item.status}}">{{item.status_text}}</text>
      </view>
      <view class="order-goods" wx:for="{{item.items}}" wx:for-item="g" wx:key="id">
        <image src="{{g.image}}" mode="aspectFill" class="goods-img" lazy-load></image>
        <view class="goods-info">
          <text class="goods-name text-ellipsis-2">{{g.name}}</text>
          <view class="goods-specs" wx:if="{{g.specsText}}">
            <text class="spec-tag">{{g.specsText}}</text>
          </view>
        </view>
        <view class="goods-right">
          <text class="goods-price">¥{{g.priceText}}</text>
          <text class="goods-qty">x{{g.quantity}}</text>
        </view>
      </view>
      <view class="order-card-foot">
        <view class="order-total">
          <text class="total-label">共{{item.totalCount}}件 实付：</text>
          <text class="price-symbol">¥</text>
          <text class="total-num">{{item.payAmountText}}</text>
        </view>
        <view class="order-actions" catchtap="noop">
          <block wx:if="{{item.status === 0}}">
            <view class="action-btn outline" catchtap="onCancel" data-id="{{item.id}}">取消订单</view>
            <view class="action-btn primary" catchtap="onPay" data-id="{{item.id}}">立即支付</view>
          </block>
          <block wx:elif="{{item.status === 2}}">
            <view class="action-btn outline" catchtap="onLogistics" data-id="{{item.id}}">查看物流</view>
            <view class="action-btn primary" catchtap="onConfirm" data-id="{{item.id}}">确认收货</view>
          </block>
          <block wx:elif="{{item.status === 3}}">
            <view class="action-btn outline" catchtap="onLogistics" data-id="{{item.id}}">查看物流</view>
            <view class="action-btn outline" catchtap="onAftersale" data-id="{{item.id}}">申请售后</view>
          </block>
          <block wx:elif="{{item.status === 4}}">
            <view class="action-btn outline" catchtap="onDelete" data-id="{{item.id}}">删除订单</view>
          </block>
        </view>
      </view>
    </view>
    <view class="load-tip">{{noMore ? '没有更多了' : (loading ? '加载中...' : '')}}</view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{!loading}}">
    <view class="empty-icon ic ic-doc"></view>
    <view class="empty-text">暂无相关订单</view>
    <navigator url="/pages/home/home" open-type="switchTab" class="empty-btn">去逛逛</navigator>
  </view>
</view>
