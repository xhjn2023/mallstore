/* pages/coupon/coupon.wxss */
.coupon-page {
  min-height: 100vh;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #fff;
  height: 88rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  border: 1rpx solid #ededed;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #111111;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 8rpx;
  width: 48rpx;
  height: 6rpx;
  background: #111111;
  border-radius: 3rpx;
}

/* 优惠券列表 */
.coupon-list {
  padding: 24rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid #ededed;
}

/* 左侧金额 */
.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #111111, #333333);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  flex-shrink: 0;
}

.amount-row {
  display: flex;
  align-items: baseline;
  color: #fff;
}

.amount-symbol {
  font-size: 28rpx;
}

.amount-num {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.threshold-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
}

/* 虚线分隔 */
.coupon-divider {
  width: 0;
  border-left: 2rpx dashed rgba(0, 0, 0, 0.1);
  margin: 20rpx 0;
}

/* 右侧信息 */
.coupon-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.coupon-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.coupon-period {
  font-size: 22rpx;
  color: #999;
}

.coupon-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-unused {
  background: #f5f5f4;
  color: #111111;
}

.status-used {
  background: #fafafa;
  color: #999;
}

.status-expired {
  background: #fafafa;
  color: #999;
}

/* 禁用样式 */
.coupon-card.disabled .coupon-left {
  background: linear-gradient(135deg, #ccc, #ddd);
}

.coupon-card.disabled .coupon-name {
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}
