/* pages/cart/cart.wxss */
.cart-page {
  min-height: 100vh;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty {
  padding: 200rpx 0 120rpx;
  text-align: center;
}
.empty-icon-wrap {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}
.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}
.empty-btn {
  display: inline-block;
  padding: 16rpx 56rpx;
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
}

/* 顶部操作栏 */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.top-bar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #333;
}
.top-bar-right {
  font-size: 26rpx;
  color: #ff4444;
}

/* 自定义复选框 */
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  box-sizing: border-box;
  position: relative;
  flex-shrink: 0;
}
.checkbox.checked {
  background: #ff4444;
  border-color: #ff4444;
}
.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 6rpx;
  width: 10rpx;
  height: 18rpx;
  border: 2rpx solid #fff;
  border-top: 0;
  border-left: 0;
  transform: rotate(45deg);
}

/* 购物车列表 */
.cart-list {
  margin: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.cart-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.cart-item:last-child {
  border-bottom: none;
}
.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin: 0 20rpx;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  height: 160rpx;
  justify-content: space-between;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}
.item-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.spec-tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.item-price {
  color: #ff4444;
}
.price-symbol {
  font-size: 22rpx;
}
.price-num {
  font-size: 32rpx;
  font-weight: 600;
}

/* 数量步进器 */
.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}
.step-btn {
  width: 52rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  background: #fafafa;
}
.step-btn.disabled {
  color: #ccc;
}
.step-num {
  min-width: 60rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 26rpx;
  border-left: 1rpx solid #e0e0e0;
  border-right: 1rpx solid #e0e0e0;
}

/* 编辑模式操作 */
.edit-actions {
  display: flex;
  gap: 16rpx;
}
.edit-action-fav,
.edit-action-del {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  border: 1rpx solid #ddd;
  color: #666;
}
.edit-action-del {
  color: #ff4444;
  border-color: #ffcfcb;
}

/* 失效商品 */
.invalid-section {
  margin: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.invalid-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.invalid-title {
  font-size: 26rpx;
  color: #999;
}
.invalid-clear {
  font-size: 24rpx;
  color: #ff4444;
}
.cart-item.invalid {
  opacity: 0.65;
}
.invalid-tag {
  font-size: 20rpx;
  color: #fff;
  background: #bbb;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
.invalid-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 100rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}
.bottom-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #333;
}
.bottom-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.total-wrap {
  display: flex;
  align-items: baseline;
  color: #ff4444;
}
.total-label {
  font-size: 26rpx;
  color: #333;
}
.total-num {
  font-size: 36rpx;
  font-weight: 600;
}
.checkout-btn {
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 48rpx;
}
.checkout-btn.disabled {
  background: #ccc;
}
.del-all-btn {
  background: #fff;
  color: #ff4444;
  border: 1rpx solid #ff4444;
  font-size: 28rpx;
  padding: 14rpx 40rpx;
  border-radius: 48rpx;
}

.safe-bottom {
  height: 40rpx;
}
