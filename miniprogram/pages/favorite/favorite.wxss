/* pages/favorite/favorite.wxss */
.favorite-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 收藏网格 */
.fav-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.fav-card {
  width: 344rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.fav-img-wrap {
  width: 100%;
  height: 344rpx;
  background: #f5f5f5;
}

.fav-img {
  width: 100%;
  height: 100%;
}

.fav-info {
  padding: 16rpx;
}

.fav-name {
  font-size: 26rpx;
  color: #333;
  height: 72rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fav-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.fav-price {
  color: #ff4444;
}

.price-symbol {
  font-size: 22rpx;
}

.price-num {
  font-size: 36rpx;
  font-weight: 600;
}

.cancel-btn {
  font-size: 22rpx;
  color: #ff4444;
  border: 1rpx solid #ff4444;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.cancel-btn:active {
  background: #fff0f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
}

.empty-btn:active {
  opacity: 0.85;
}
