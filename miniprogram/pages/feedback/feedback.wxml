<!-- pages/feedback/feedback.wxml -->
<view class="feedback-page">
  <!-- 反馈类型 -->
  <view class="section">
    <view class="section-title">反馈类型</view>
    <view class="type-list">
      <view class="type-item {{form.type === item ? 'active' : ''}}" wx:for="{{typeList}}" wx:key="*this" bindtap="onTypeChange" data-type="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 反馈内容 -->
  <view class="section">
    <view class="section-title">反馈内容</view>
    <view class="textarea-wrap">
      <textarea class="feedback-textarea" placeholder="请详细描述您遇到的问题或建议（最多500字）" value="{{form.content}}" bindinput="onContentInput" maxlength="500" auto-height></textarea>
      <view class="char-count">{{form.content.length}}/500</view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section">
    <view class="section-title">联系方式（选填）</view>
    <input class="contact-input" placeholder="请输入手机号或微信号，方便我们联系您" value="{{form.contact}}" bindinput="onContactInput" maxlength="50" />
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">提交反馈</button>
</view>
