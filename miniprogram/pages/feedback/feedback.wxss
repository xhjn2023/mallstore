/* pages/feedback/feedback.wxss */
.feedback-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 反馈类型 */
.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  padding: 16rpx 36rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #eee;
  border: 1rpx solid #ededed;
}

.type-item.active {
  color: #111111;
  border-color: #111111;
  background: #f5f5f4;
}

/* 文本域 */
.textarea-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #ededed;
  position: relative;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 联系方式 */
.contact-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #ededed;
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  margin: 0;
  border-radius: 0;
  background: linear-gradient(135deg, #111111, #333333);
  color: #fff;
  text-align: center;
  padding: 30rpx 0;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1.4;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.85;
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #f5f5f4, #f5f5f4);
  color: #fff;
  opacity: 1;
}
