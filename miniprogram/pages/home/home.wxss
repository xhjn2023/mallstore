/* pages/home/home.wxss */
.home {
  padding-bottom: 120rpx;
}

/* 搜索框 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}
.search-input {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  gap: 8rpx;
}
.search-icon {
  font-size: 28rpx;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
  margin: 16rpx 0;
}
.banner-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

/* 分类导航 */
.category-nav {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: 0 16rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
}
.cat-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}
.cat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fff5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.cat-name {
  font-size: 24rpx;
  color: #333;
}

/* 秒杀 */
.seckill-section {
  background: #fff;
  margin: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.countdown {
  font-size: 24rpx;
  color: #ff4444;
  background: #fff0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: monospace;
}
.section-more {
  font-size: 24rpx;
  color: #999;
}
.seckill-scroll {
  white-space: nowrap;
}
.seckill-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  vertical-align: top;
}
.seckill-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}
.seckill-info {
  margin-top: 8rpx;
}
.seckill-price {
  display: block;
  color: #ff4444;
  font-size: 32rpx;
  font-weight: 600;
}
.seckill-original {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
}
.seckill-progress {
  margin-top: 8rpx;
  position: relative;
  height: 28rpx;
  background: #fff0f0;
  border-radius: 14rpx;
  overflow: hidden;
}
.progress-bar {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: linear-gradient(90deg, #ff4444, #ff8a8a);
  border-radius: 14rpx;
}
.progress-text {
  position: relative;
  font-size: 18rpx;
  color: #fff;
  text-align: center;
  line-height: 28rpx;
  display: block;
}

/* 热销推荐 */
.hot-section {
  margin-top: 16rpx;
  padding: 24rpx;
}
.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.product-card {
  width: 344rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.product-img {
  width: 100%;
  height: 344rpx;
  background: #f5f5f5;
}
.product-info {
  padding: 16rpx;
}
.product-name {
  font-size: 26rpx;
  color: #333;
  height: 72rpx;
  line-height: 36rpx;
}
.product-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
}
.product-price {
  color: #ff4444;
}
.price-symbol {
  font-size: 22rpx;
}
.price-num {
  font-size: 36rpx;
  font-weight: 600;
}
.product-sales {
  font-size: 20rpx;
  color: #999;
}

.safe-bottom {
  height: 40rpx;
}
