<!-- pages/home/home.wxml -->
<view class="home">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input" bindtap="goSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索商品</text>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots autoplay circular interval="4000" duration="500" wx:if="{{banners.length}}">
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}">
      <image src="{{item.image}}" mode="aspectFill" class="banner-img" lazy-load />
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <view class="category-nav" wx:if="{{categories.length}}">
      <view class="cat-item" wx:for="{{categories}}" wx:key="id" bindtap="goCategory" data-id="{{item.id}}" data-name="{{item.name}}">
        <view class="cat-icon">
          <image wx:if="{{item._isImageIcon}}" class="cat-icon-media" src="{{item.icon}}" mode="aspectFit" />
          <text wx:else>{{item.icon || '📦'}}</text>
        </view>
        <text class="cat-name">{{item.name}}</text>
      </view>
  </view>

  <!-- 限时秒杀 -->
  <view class="seckill-section" wx:if="{{seckills.length}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-text">⚡ 限时秒杀</text>
        <text class="countdown">{{countdownText}}</text>
      </view>
      <text class="section-more" bindtap="goSeckill">更多 ></text>
    </view>
    <scroll-view scroll-x class="seckill-scroll" enhanced show-scrollbar="{{false}}">
      <view class="seckill-item" wx:for="{{seckills}}" wx:key="id" bindtap="goDetail" data-id="{{item.product_id}}">
        <image src="{{item.product.main_image}}" mode="aspectFill" class="seckill-img" lazy-load />
        <view class="seckill-info">
          <text class="seckill-price">¥{{item.seckillPriceText}}</text>
          <text class="seckill-original">¥{{item.originalPriceText}}</text>
        </view>
        <view class="seckill-progress">
          <view class="progress-bar" style="width: {{item.progress}}%"></view>
          <text class="progress-text">已抢{{item.progress}}%</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 热销推荐 -->
  <view class="hot-section">
    <view class="section-header">
      <view class="section-title">🔥 热销推荐</view>
    </view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image src="{{item.main_image}}" mode="aspectFill" class="product-img" lazy-load />
        <view class="product-info">
          <text class="product-name text-ellipsis-2">{{item.name}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{item.priceText}}</text>
            </view>
            <text class="product-sales">已售{{item.salesText}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
