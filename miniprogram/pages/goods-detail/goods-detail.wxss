/* pages/goods-detail/goods-detail.wxss */
.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 骨架屏 */
.skeleton-wrap {
  padding: 0;
}
.skeleton-swiper {
  width: 100%;
  height: 750rpx;
}
.skeleton-info {
  padding: 24rpx;
}
.skeleton-price {
  width: 200rpx;
  height: 48rpx;
  margin-bottom: 20rpx;
}
.skeleton-name {
  width: 90%;
  height: 36rpx;
  margin-bottom: 20rpx;
}
.skeleton-line {
  width: 60%;
  height: 28rpx;
}
.skeleton-block {
  width: 100%;
  height: 200rpx;
  margin-top: 20rpx;
}

/* 图片轮播 */
.img-swiper {
  width: 100%;
  height: 750rpx;
}
.swiper-img {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.info-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.price-box {
  color: #ff4444;
}
.price-symbol {
  font-size: 28rpx;
  color: #ff4444;
}
.price-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #ff4444;
}
.price-original {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}
.product-name {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-top: 16rpx;
  line-height: 1.5;
}
.info-row {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
}
.info-item {
  font-size: 24rpx;
  color: #999;
}

/* 规格选择卡片 */
.spec-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}
.spec-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 24rpx;
}
.spec-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.spec-value.placeholder {
  color: #999;
}
.spec-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 商品详情 */
.detail-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.detail-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

/* 评价 */
.comment-card {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.comment-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.comment-item:last-child {
  border-bottom: none;
}
.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f5f5;
  margin-right: 16rpx;
}
.comment-user {
  flex: 1;
}
.comment-name {
  font-size: 26rpx;
  color: #333;
  display: block;
}
.comment-stars {
  display: flex;
  margin-top: 4rpx;
}
.star {
  font-size: 22rpx;
  margin-right: 2rpx;
}
.star-on {
  color: #ff4444;
}
.star-off {
  color: #ddd;
}
.comment-time {
  font-size: 22rpx;
  color: #ccc;
}
.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}
.comment-empty {
  padding: 60rpx 0;
  text-align: center;
}
.comment-empty .empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 12rpx 24rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 50;
}
.action-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  gap: 4rpx;
}
.icon-emoji {
  font-size: 40rpx;
}
.icon-text {
  font-size: 20rpx;
  color: #666;
}
.icon-text.fav-on,
.icon-emoji.fav-on {
  color: #ff4444;
}
.action-btns {
  flex: 1;
  display: flex;
  margin-left: 16rpx;
  gap: 16rpx;
}
.btn-cart {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffb347, #ff8a3d);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx 0 0 40rpx;
}
.btn-buy {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 0 40rpx 40rpx 0;
}

/* 规格弹窗 */
.sku-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}
.sku-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.sku-popup.show {
  transform: translateY(0);
}

/* 弹窗头部 */
.popup-header {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.popup-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  margin-top: -40rpx;
  border: 4rpx solid #fff;
}
.popup-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 8rpx;
}
.popup-price {
  color: #ff4444;
}
.popup-price .price-symbol {
  font-size: 28rpx;
}
.popup-price .price-num {
  font-size: 44rpx;
  font-weight: 700;
}
.popup-stock {
  font-size: 24rpx;
  color: #999;
}
.popup-selected {
  font-size: 26rpx;
  color: #333;
}
.popup-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 32rpx;
  color: #ccc;
  padding: 8rpx;
}

/* 弹窗内容 */
.popup-body {
  flex: 1;
  padding: 24rpx;
  max-height: 600rpx;
}
.spec-group {
  margin-bottom: 32rpx;
}
.spec-group-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}
.spec-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.spec-value-item {
  padding: 14rpx 28rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  border: 2rpx solid transparent;
}
.spec-value-item.selected {
  background: #fff0f0;
  color: #ff4444;
  border-color: #ff4444;
}

/* 数量选择 */
.qty-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.qty-stepper {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.qty-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #f5f5f5;
  font-size: 32rpx;
  color: #333;
  border-radius: 8rpx;
}
.qty-btn.disabled {
  color: #ccc;
}
.qty-num {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

/* 弹窗底部 */
.popup-footer {
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.popup-confirm {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff4444, #ff6b6b);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}
