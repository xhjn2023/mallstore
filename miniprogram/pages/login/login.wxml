<!-- pages/login/login.wxml -->
<view class="login-page">
  <!-- 顶部品牌区 -->
  <view class="brand">
    <image class="brand-logo" src="/assets/default-avatar.png" mode="aspectFill"></image>
    <text class="brand-name">商城欢迎您</text>
    <text class="brand-tip">登录后享受会员专属权益</text>
  </view>

  <!-- 方式切换 -->
  <view class="tabs">
    <view class="tab {{tab === 'wechat' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechat">微信登录</view>
    <view class="tab {{tab === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-tab="phone">手机号登录</view>
  </view>

  <!-- 微信登录面板 -->
  <view class="panel" wx:if="{{tab === 'wechat'}}">
    <view class="wx-icon">💬</view>
    <text class="panel-tip">使用微信账号一键登录，安全便捷</text>
    <button class="btn-primary wx-btn" bindtap="onWechatLogin" loading="{{logging}}" disabled="{{logging}}">
      微信一键登录
    </button>
  </view>

  <!-- 手机号登录面板 -->
  <view class="panel" wx:if="{{tab === 'phone'}}">
    <view class="field">
      <text class="field-label">+86</text>
      <input class="field-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field">
      <input class="field-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
      <view class="code-btn {{counting ? 'disabled' : ''}}" bindtap="onSendCode">
        {{counting ? countdown + 's' : '获取验证码'}}
      </view>
    </view>
    <button class="btn-primary phone-btn" bindtap="onPhoneLogin" loading="{{logging}}" disabled="{{logging}}">
      登录 / 注册
    </button>
    <text class="code-hint">验证码默认为 123456（演示环境）</text>
  </view>

  <!-- 底部协议 -->
  <view class="agreement">
    登录即代表同意<text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text>
  </view>
</view>
