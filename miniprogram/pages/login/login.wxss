/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* 品牌区 */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.brand-logo-img {
  width: 100%;
  height: 100%;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-top: 28rpx;
}

.brand-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 方式切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #ff4444;
  color: #fff;
  font-weight: 600;
}

/* 面板 */
.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 56rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.panel-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
}

/* 输入框 */
.field {
  width: 100%;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.field-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-right: 16rpx;
}

.field-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.code-btn {
  font-size: 26rpx;
  color: #ff4444;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ff4444;
  border-radius: 8rpx;
  white-space: nowrap;
}

.code-btn.disabled {
  color: #bbb;
  border-color: #eee;
}

/* 主按钮 */
.btn-primary {
  width: 100%;
  margin-top: 40rpx;
  background: #ff4444;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  height: 92rpx;
  line-height: 92rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #ffb3b3;
  color: #fff;
}

.code-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 24rpx;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 60rpx;
  padding: 0 20rpx;
  line-height: 1.5;
}

.agree-check {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  margin-right: 12rpx;
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: all 0.2s;
}

.agree-check.checked {
  background: #ff4444;
  border-color: #ff4444;
}

.agree-tick {
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.agree-text {
  flex: 1;
}

.link {
  color: #ff4444;
}
