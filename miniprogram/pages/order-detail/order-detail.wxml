<!-- pages/order-detail/order-detail.wxml -->
<view class="detail-page" wx:if="{{order}}">
  <!-- 状态横幅 -->
  <view class="status-banner status-bg-{{order.status}}">
    <view class="status-text">{{order.status_text}}</view>
    <view class="status-desc">{{statusDesc}}</view>
  </view>

  <!-- 收货地址 -->
  <view class="address-card" wx:if="{{order.address}}">
    <view class="addr-icon ic ic-location"></view>
    <view class="addr-info">
      <view class="addr-user">
        <text class="addr-name">{{order.address.name}}</text>
        <text class="addr-phone">{{order.address.phone}}</text>
      </view>
      <view class="addr-detail">{{order.address.province}}{{order.address.city}}{{order.address.district}}{{order.address.detail}}</view>
    </view>
  </view>

  <!-- 订单商品 -->
  <view class="goods-card">
    <view class="goods-item" wx:for="{{order.items}}" wx:key="id">
      <image src="{{item.image}}" mode="aspectFill" class="goods-img" lazy-load></image>
      <view class="goods-info">
        <view class="goods-name text-ellipsis-2">{{item.name}}</view>
        <view class="goods-specs" wx:if="{{item.specsText}}">
          <text class="spec-tag">{{item.specsText}}</text>
        </view>
        <view class="goods-bottom">
          <view class="goods-price">
            <text class="price-symbol">¥</text>
            <text class="price-num">{{item.priceText}}</text>
          </view>
          <text class="goods-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 售后信息 -->
  <view class="aftersale-card" wx:if="{{order.aftersale}}">
    <view class="aftersale-title">售后信息</view>
    <view class="info-row">
      <text class="info-label">售后类型</text>
      <text class="info-val">{{order.aftersale.type === 1 ? '仅退款' : '退货退款'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">申请原因</text>
      <text class="info-val">{{order.aftersale.reason || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">处理状态</text>
      <text class="info-val {{order.aftersale.status === 0 ? 'warn' : (order.aftersale.status === 1 ? 'success' : 'danger')}}">{{aftersaleStatusText}}</text>
    </view>
    <view class="info-row" wx:if="{{order.aftersale.admin_remark}}">
      <text class="info-label">处理说明</text>
      <text class="info-val">{{order.aftersale.admin_remark}}</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <view class="info-val copy-val" bindtap="onCopyOrderNo">
        <text>{{order.order_no}}</text>
        <text class="copy-btn">复制</text>
      </view>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-val">{{createdTimeText}}</text>
    </view>
    <view class="info-row" wx:if="{{order.pay_time}}">
      <text class="info-label">支付时间</text>
      <text class="info-val">{{payTimeText}}</text>
    </view>
    <view class="info-row" wx:if="{{order.ship_time}}">
      <text class="info-label">发货时间</text>
      <text class="info-val">{{shipTimeText}}</text>
    </view>
    <view class="info-row" wx:if="{{order.ship_no}}">
      <text class="info-label">物流单号</text>
      <view class="info-val copy-val" bindtap="onCopyShipNo">
        <text>{{order.ship_no}}</text>
        <text class="copy-btn" wx:if="{{order.ship_company}}">{{order.ship_company}}</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">订单备注</text>
      <text class="info-val">{{order.remark}}</text>
    </view>
  </view>

  <!-- 金额明细 -->
  <view class="amount-card">
    <view class="amount-row">
      <text class="amount-label">商品总额</text>
      <text class="amount-val">¥{{totalAmountText}}</text>
    </view>
    <view class="amount-row">
      <text class="amount-label">运费</text>
      <text class="amount-val">{{order.freight > 0 ? '¥' + freightText : '免运费'}}</text>
    </view>
    <view class="amount-row" wx:if="{{order.discount > 0}}">
      <text class="amount-label">优惠</text>
      <text class="amount-val discount-val">-¥{{discountText}}</text>
    </view>
    <view class="amount-divider"></view>
    <view class="amount-row total-row">
      <text class="amount-label">实付款</text>
      <view class="pay-amount">
        <text class="price-symbol">¥</text>
        <text class="pay-num">{{payAmountText}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{showActions}}">
    <block wx:if="{{order.status === 0}}">
      <view class="action-btn outline" bindtap="onCancel">取消订单</view>
      <view class="action-btn primary" bindtap="onPay">立即支付</view>
    </block>
    <block wx:elif="{{order.status === 2}}">
      <view class="action-btn outline" bindtap="onLogistics">查看物流</view>
      <view class="action-btn primary" bindtap="onConfirm">确认收货</view>
    </block>
    <block wx:elif="{{order.status === 3}}">
      <view class="action-btn outline" bindtap="onLogistics">查看物流</view>
      <view class="action-btn outline" bindtap="onAftersale">申请售后</view>
    </block>
    <block wx:elif="{{order.status === 4}}">
      <view class="action-btn outline" bindtap="onDelete">删除订单</view>
    </block>
  </view>

  <view class="safe-bottom"></view>
</view>

<!-- 加载中 -->
<view class="loading" wx:if="{{!order && loading}}">
  <text>加载中...</text>
</view>
