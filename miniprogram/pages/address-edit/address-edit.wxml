<!-- pages/address-edit/address-edit.wxml -->
<view class="edit-page">
  <view class="form-card">
    <!-- 姓名 -->
    <view class="form-item">
      <text class="form-label">收货人</text>
      <input class="form-input" placeholder="请输入收货人姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <!-- 所在地区 -->
    <view class="form-item">
      <text class="form-label">所在地区</text>
      <picker mode="region" value="{{[form.province, form.city, form.district]}}" bindchange="onRegionChange">
        <view class="form-picker {{form.province ? '' : 'placeholder'}}">
          <text wx:if="{{form.province}}">{{form.province}} {{form.city}} {{form.district}}</text>
          <text wx:else>请选择省/市/区</text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>

    <!-- 详细地址 -->
    <view class="form-item form-item-textarea">
      <text class="form-label">详细地址</text>
      <textarea class="form-textarea" placeholder="请输入详细地址（街道、楼牌号等）" value="{{form.detail}}" bindinput="onInput" data-field="detail" maxlength="100" auto-height></textarea>
    </view>
  </view>

  <!-- 设为默认 -->
  <view class="default-card">
    <view class="default-row">
      <text class="default-label">设为默认地址</text>
      <switch checked="{{form.is_default}}" bindchange="onDefaultChange" color="#111111" />
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="onSave" loading="{{submitting}}" disabled="{{submitting}}">保存</button>
</view>
